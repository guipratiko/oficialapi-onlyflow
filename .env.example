PORT=4338
# Token do System User da Meta (WhatsApp Business); usado para enviar mensagens
META_SYSTEM_USER_TOKEN=
# App ID da Meta (obrigatório para upload da foto de perfil WhatsApp)
META_APP_ID=
# Chave para autorizar chamadas do Backend (header x-api-key ou Authorization: Bearer)
API_KEY=
CORS_ORIGIN=http://localhost:3000
# URL do Backend (opcional, para health/checks)
BACKEND_URL=http://localhost:4331
